@model IEnumerable<Library.Domain.Book>

@{
    ViewData["Title"] = "Books";
}

<h2>Books</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">Create New Book</a>
</p>

<form method="get" class="mb-3 d-flex gap-2 align-items-center">
    <input type="text" name="search" value="@(ViewData["Search"])" placeholder="Search title or author" class="form-control w-auto" />

    <select name="category" class="form-select w-auto">
        <option value="">All Categories</option>
        @foreach (var cat in ViewBag.Categories as List<string>)
        {
            <option value="@cat" selected="@(ViewData["SelectedCategory"]?.ToString() == cat ? "selected" : null)">
                @cat
            </option>
        }
    </select>

    <select name="availability" class="form-select w-auto">
        <option value="">All</option>
        <option value="Available" selected="@(ViewData["SelectedAvailability"]?.ToString() == "Available" ? "selected" : null)">Available</option>
        <option value="OnLoan" selected="@(ViewData["SelectedAvailability"]?.ToString() == "OnLoan" ? "selected" : null)">On Loan</option>
    </select>

    <button type="submit" class="btn btn-secondary">Filter</button>
</form>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Title)</th>
            <th>@Html.DisplayNameFor(model => model.Author)</th>
            <th>@Html.DisplayNameFor(model => model.Isbn)</th>
            <th>@Html.DisplayNameFor(model => model.Category)</th>
            <th>@Html.DisplayNameFor(model => model.IsAvailable)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@Html.DisplayFor(m => book.Title)</td>
                <td>@Html.DisplayFor(m => book.Author)</td>
                <td>@Html.DisplayFor(m => book.Isbn)</td>
                <td>@Html.DisplayFor(m => book.Category)</td>
                <td>@(book.IsAvailable ? "Yes" : "No")</td>
                <td>
                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@book.Id">Edit</a>
                    <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@book.Id">Details</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@book.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>