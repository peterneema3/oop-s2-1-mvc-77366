@model IEnumerable<Library.Domain.Loan>
@{
    ViewData["Title"] = "Loans";
}

<h1>Loans</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Loan</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Book</th>
            <th>Member</th>
            <th>Loan Date</th>
            <th>Due Date</th>
            <th>Returned Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var loan in Model)
        {
            <tr>
                <td>@loan.Book?.Title</td>
                <td>@loan.Member?.FullName</td>
                <td>@loan.LoanDate.ToShortDateString()</td>
                <td>@loan.DueDate.ToShortDateString()</td>
                <td>@(loan.ReturnedDate.HasValue? loan.ReturnedDate.Value.ToShortDateString() : "-")</td>
                <td>
                    @if (loan.ReturnedDate == null && loan.DueDate < DateTime.Today)
                    {
                        <span class="text-danger">Overdue</span>
                    }
                    else if (loan.ReturnedDate == null)
                    {
                        <span class="text-success">On Loan</span>
                    }
                    else
                    {
                        <span class="text-muted">Returned</span>
                    }
                </td>
                <td>
                    @if (loan.ReturnedDate == null)
                    {
                        <form asp-action="Return" method="post" style="display:inline">
                            <input type="hidden" name="id" value="@loan.Id" />
                            <button type="submit" class="btn btn-sm btn-success">Return</button>
                        </form>
                    }
                    <a asp-action="Delete" asp-route-id="@loan.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>