@model IEnumerable<Library.Domain.Member>

@{
    ViewData["Title"] = "Members";
}

<h2>Members</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">Create New Member</a>
</p>

<!-- Search / Filter Form -->
<form method="get" class="mb-3 d-flex gap-2 align-items-center">
    <input type="text" name="search" value="@ViewData["Search"]" placeholder="Search by name or email" class="form-control w-auto" />
    <button type="submit" class="btn btn-secondary">Filter</button>
</form>

<!-- Members Table -->
<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.FullName)</th>
            <th>@Html.DisplayNameFor(model => model.Email)</th>
            <th>@Html.DisplayNameFor(model => model.Phone)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var member in Model)
        {
            <tr>
                <td>@Html.DisplayFor(m => member.FullName)</td>
                <td>@Html.DisplayFor(m => member.Email)</td>
                <td>@Html.DisplayFor(m => member.Phone)</td>
                <td>
                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@member.Id">Edit</a>
                    <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@member.Id">Details</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@member.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>